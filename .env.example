# Optional — only for local testing against your Mac.
# If not set, the app uses https://proxy.previewcloud.cloud
# EXPO_PUBLIC_API_BASE_URL=http://192.168.0.165:8080

# Required for Docker APK build (scripts/docker-build-apk.sh)
# Get from: https://expo.dev/accounts/[account]/settings/access-tokens
# EXPO_TOKEN=your_expo_access_token

# Note: Docker debug builds do NOT need EXPO_TOKEN.
# EXPO_TOKEN is only required for EAS cloud/signed release builds.
